# Model Training Configuration
# Models
MODEL_TYPES=LogisticRegression,RandomForest
MLFLOW_EXPERIMENT_NAME=HeartDiseaseClassification

# General
RANDOM_SEED=42
TEST_SIZE=0.2

# Logistic Regression
LR_MAX_ITER=1000

# Random Forest
RF_N_ESTIMATORS=100
RF_MAX_DEPTH=10

# Data
DATA_PATH=./data/raw
PROCESSED_DATA_PATH=./data/processed

# Output
MODEL_OUTPUT_PATH=./models
LOG_DIR=./logs
OUTPUT_DIR=./outputs

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=HeartDiseaseClassification

# Environment
ENVIRONMENT=development
DEBUG=True